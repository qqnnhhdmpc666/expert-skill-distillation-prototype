# External source snapshots and dependency caches
external_repos/
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/

# Secrets and local environment
.env
.env.*
!.env.example
*.key
*.pem

# Heavy/generated runtime outputs
outputs/**/job.log
outputs/**/trial.log
outputs/**/agent/
outputs/**/verifier/
