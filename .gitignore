# External source snapshots and dependency caches
external_repos/
.venv/
venv/
swebench-venv/
SWE-bench/
.uv-cache/
.uv-python/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/

# Secrets and local environment
.env
.env.*
!.env.example
*.key
*.pem

# Heavy/generated runtime outputs
outputs/**/job.log
outputs/**/trial.log
outputs/**/agent/
outputs/**/verifier/
outputs/**/config.json
outputs/**/result.json
outputs/external_swebench/**/image_build_dir

# Keep lightweight smoke-test evidence committed
!outputs/harbor-smoke/**
